# Neon (copy from Neon dashboard — never commit real passwords)
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

# Generate for production (e.g. openssl rand -hex 32)
SESSION_SECRET=

# Optional: bearer token for /api/cron/cleanup
CRON_SECRET=

# Optional: canonical URL for share links from the desktop app
NEXT_PUBLIC_APP_URL=

# Contact form email delivery (server-side only)
CONTACT_TO_EMAIL=
CONTACT_FROM_EMAIL=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
